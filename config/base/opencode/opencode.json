{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "lsp": true,
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "echo *": "allow",
      "head *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "sw_vers": "allow",
      "sw_vers *": "allow",
      "xcode-select -p": "allow",
      "gcc --version": "allow",
      "make --version": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow"
    },
    "edit": "ask"
  },
  "provider": {
    "bailian-coding-plan": {
      "npm": "@ai-sdk/anthropic",
      "name": "Alibaba Cloud Model Studio",
      "options": {
        "baseURL": "https://dashscope.aliyuncs.com/apps/anthropic/v1",
        "apiKey": "{env:OPENCODE_API_KEY}"
      },
      "models": {
        "qwen3.7-plus": {
          "name": "Qwen3.7 Plus",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 1024
            }
          }
        },
        "qwen3.6-plus": {
          "name": "Qwen3.6 Plus",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 1024
            }
          }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 1024
            }
          }
        },
        "glm-5": {
          "name": "GLM-5",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 1024
            }
          }
        },
        "MiniMax-M2.5": {
          "name": "MiniMax M2.5"
        }
      }
    }
  }
}
